{{ define "configuration/secrets" }}
<!doctype html>
<html lang="en">

<head>
  <title>NetKube</title>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/png" href="/public/logo/logo.png" />
  <link rel="stylesheet" href="/public/global.css" />
  <link rel="stylesheet" href="/public/css/overview.css" />
  <link rel="stylesheet" href="/public/css/deployments.css" />
  <script src="/public/js/app/core/storage/local.js" defer></script>
  <script src="/public/js/app/ui/yaml/highlight.js" defer></script>
  <script src="/public/js/app/core/dom/text.js" defer></script>
  <script src="/public/js/app/core/dom/page-meta.js" defer></script>
  <script src="/public/js/app/core/refresh/polling.js" defer></script>
  <script src="/public/js/app/core/api/cluster.js" defer></script>
  <script src="/public/js/app/ui/drawer/yaml.js" defer></script>
  <script src="/public/js/app/configuration/v1/secrets/boot.js" defer></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" />
</head>

<body>
  {{ template "sidebar" . }}
  <main class="main-content dashboard-page deployments-page">
    <section class="dashboard-hero">
      <div>
        <p class="eyebrow">Configuration inventory</p>
        <div class="hero-copy">
          <img src="/public/logo/kubernetes.svg" alt="NetKube logo" class="hero-logo" />
          <span class="hero-user" id="secretsHeroTitle">Secrets</span>
        </div>
      </div>

      <div class="hero-meta">
        <div class="meta-pill">
          <span class="meta-label">Context</span>
          <strong id="selectedContext">-</strong>
        </div>
        <div class="meta-pill">
          <span class="meta-label">Last refresh</span>
          <strong id="lastRefresh">just now</strong>
        </div>
      </div>
    </section>

    <section class="deployments-toolbar" aria-label="Secrets controls">
      <div class="deployments-toolbar__left">
        <label class="search-control" for="secretsSearch">
          <i class="fa fa-search" aria-hidden="true"></i>
          <input id="secretsSearch" type="search" placeholder="Search secrets" />
        </label>
      </div>
    </section>

    <section class="deployments-table-panel">
      <div class="deployments-table-panel__header">
        <div>
          <p class="summary-kicker">Secrets</p>
        </div>
        <span class="table-hint" id="secretsTableCount">0 rows</span>
      </div>

      <div class="deployments-table-wrap" role="region" aria-label="Secrets table" tabindex="0">
        <table class="deployments-table">
          <thead>
            <tr>
              <th>Namespace</th>
              <th>Name</th>
              <th>Type</th>
              <th>Data keys</th>
              <th>Age</th>
            </tr>
          </thead>
          <tbody id="secretsTableBody">
            <tr>
              <td colspan="5">Loading secrets...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <div class="resource-drawer-backdrop" id="secretDataBackdrop" hidden></div>
    <aside class="resource-drawer" id="secretDataDrawer" hidden>
      <div class="resource-drawer__header">
        <div>
          <p class="summary-kicker">Secret Data</p>
          <h2 id="secretDataTitle">Select a secret</h2>
        </div>
        <button class="resource-drawer__close" id="secretDataClose" type="button" aria-label="Close secret data panel">
          <i class="fa fa-times" aria-hidden="true"></i>
        </button>
      </div>
      <pre class="resource-drawer__content" id="secretDataContent">Click a secret to view its data.</pre>
    </aside>
  </main>
</body>

</html>
{{ end }}