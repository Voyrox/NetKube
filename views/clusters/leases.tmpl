{{ define "clusters/leases" }}
<!doctype html>
<html>
  <head>
    <title>NetKube</title>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/public/logo/logo.png" />
    <link rel="stylesheet" href="/public/global.css" />
    <link rel="stylesheet" href="/public/css/overview.css" />
    <link rel="stylesheet" href="/public/css/deployments.css" />
    <script src="/public/js/localStorage.js" defer></script>
    <script src="/public/js/clusterApi.js" defer></script>
    <script src="/public/js/clusterLeases.js" defer></script>
            <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css"
    />
  </head>
  <body>
    {{ template "sidebar" . }}
    <main class="main-content dashboard-page deployments-page">
      <section class="dashboard-hero">
        <div>
          <p class="eyebrow">Cluster inventory</p>
          <div class="hero-copy">
            <img src="/public/logo/kubernetes.svg" alt="NetKube logo" class="hero-logo" />
            <span class="hero-user" id="leasesHeroTitle">Leases</span>
          </div>
        </div>

        <div class="hero-meta">
          <div class="meta-pill">
            <span class="meta-label">Context</span>
            <strong id="selectedContext">-</strong>
          </div>
          <div class="meta-pill">
            <span class="meta-label">Last refresh</span>
            <strong id="lastRefresh">just now</strong>
          </div>
        </div>
      </section>

      <section class="deployments-table-panel">
        <div class="deployments-table-panel__header">
          <div>
            <p class="summary-kicker">Leases</p>
          </div>
          <span class="table-hint" id="leasesTableCount">0 rows</span>
        </div>

        <div class="deployments-table-wrap" role="region" aria-label="Leases table" tabindex="0">
          <table class="deployments-table">
            <thead>
              <tr>
                <th>Namespace</th>
                <th>Name</th>
                <th>Holder</th>
                <th>Last Renew</th>
                <th>Age</th>
              </tr>
            </thead>
            <tbody id="leasesTableBody">
              <tr>
                <td colspan="5">Loading leases...</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <div class="resource-drawer-backdrop" id="leaseYamlBackdrop" hidden></div>
      <aside class="resource-drawer" id="leaseYamlDrawer" hidden>
        <div class="resource-drawer__header">
          <div>
            <p class="summary-kicker">Lease YAML</p>
            <h2 id="leaseYamlTitle">Select a lease</h2>
          </div>
          <button class="resource-drawer__close" id="leaseYamlClose" type="button" aria-label="Close YAML panel">
            <i class="fa fa-times" aria-hidden="true"></i>
          </button>
        </div>
        <pre class="resource-drawer__content" id="leaseYamlContent">Click a lease to view its YAML.</pre>
      </aside>
    </main>
  </body>
</html>
{{ end }}

