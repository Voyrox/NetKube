{{ define "clusters/details/node" }}
<!doctype html>
<html lang="en">

<head>
  <title>NetKube</title>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <script src="https://cdn.jsdelivr.net/npm/js-yaml@4.1.0/dist/js-yaml.min.js"></script>
  <link rel="icon" href="/public/logo/favicon.ico" type="image/x-icon" />
  <link rel="apple-touch-icon" href="/public/logo/logo.png" />
  <link rel="stylesheet" href="/public/global.css" />
  <link rel="stylesheet" href="/public/css/overview.css" />
  <link rel="stylesheet" href="/public/css/clusters/detail.css" />
  <script src="/public/js/app/core/storage/local.js" defer></script>
  <script src="/public/js/app/core/dom/text.js" defer></script>
  <script src="/public/js/app/core/dom/page-meta.js" defer></script>
  <script src="/public/js/app/core/refresh/polling.js" defer></script>
  <script src="/public/js/app/core/api/cluster.js" defer></script>
  <script src="/public/js/app/ui/status/chips.js" defer></script>
  <script src="/public/js/app/cluster/v1/node/boot.js" defer></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" />
</head>

<body>
  {{ template "sidebar" . }}
  <main class="main-content dashboard-page cluster-detail-page">
    <section class="dashboard-hero">
      <div>
        <p class="eyebrow">Cluster resource</p>
        <div class="hero-copy">
          <img src="/public/logo/kubernetes.svg" alt="NetKube logo" class="hero-logo" />
          <span class="hero-user" id="nodeHeroTitle">Node</span>
        </div>
      </div>

      <div class="hero-meta">
        <div class="meta-pill">
          <span class="meta-label">Status</span>
          <strong id="nodeStatusMeta">-</strong>
        </div>
        <div class="meta-pill">
          <span class="meta-label">Role</span>
          <strong id="nodeRoleMeta">-</strong>
        </div>
      </div>
    </section>

    <section class="cluster-summary-card">
      <div class="cluster-panel__header">
        <div>
          <p class="summary-kicker">Node</p>
          <h2>Node health snapshot</h2>
        </div>
        <span class="status-chip status-chip--healthy" id="nodeLiveStatus">Live</span>
      </div>

      <div class="cluster-summary-card__grid">
        <article class="cluster-fact-card">
          <span>CPU pressure</span>
          <strong id="nodeCpuPressure">-</strong>
        </article>
        <article class="cluster-fact-card">
          <span>Memory pressure</span>
          <strong id="nodeMemoryPressure">-</strong>
        </article>
        <article class="cluster-fact-card">
          <span>Disk pressure</span>
          <strong id="nodeDiskPressure">-</strong>
        </article>
      </div>
    </section>

    <section class="cluster-detail-grid">
      <section class="cluster-panel">
        <div class="cluster-panel__header">
          <div>
            <p class="summary-kicker">Details</p>
            <h2>Node details</h2>
          </div>
        </div>

        <div class="cluster-kv-list">
          <div><span>Kubernetes version</span><strong id="nodeKubeletVersion">-</strong></div>
          <div><span>Container runtime</span><strong id="nodeContainerRuntime">-</strong></div>
          <div><span>OS / Kernel</span><strong id="nodeOsKernel">-</strong></div>
          <div><span>Architecture</span><strong id="nodeArchitecture">-</strong></div>
          <div><span>Internal IP</span><strong id="nodeInternalIP">-</strong></div>
          <div><span>Pod CIDR</span><strong id="nodePodCIDR">-</strong></div>
        </div>

        <div class="cluster-panel__section">
          <p class="summary-kicker">Labels</p>
          <ul class="cluster-tag-list" id="nodeLabelsList">
            <li><span class="cluster-tag-key">Loading</span><strong class="cluster-tag-value">labels...</strong></li>
          </ul>
        </div>
      </section>

      <section class="cluster-panel">
        <div class="cluster-panel__header">
          <div>
            <p class="summary-kicker">Capacity</p>
            <h2>Allocatable</h2>
          </div>
        </div>

        <div class="cluster-kv-list">
          <div><span>CPU</span><strong id="nodeAllocatableCPU">-</strong></div>
          <div><span>Memory</span><strong id="nodeAllocatableMemory">-</strong></div>
          <div><span>Pods</span><strong id="nodeAllocatablePods">-</strong></div>
          <div><span>Ephemeral storage</span><strong id="nodeAllocatableStore">-</strong></div>
        </div>

        <div class="cluster-panel__section">
          <p class="summary-kicker">Conditions</p>
          <div class="cluster-timeline" id="nodeConditionsList">
            <p class="cluster-empty">Loading conditions...</p>
          </div>
        </div>
      </section>
    </section>

    <section class="cluster-panel">
      <div class="cluster-panel__header">
        <div>
          <p class="summary-kicker">Recent activity</p>
          <h2>Node timeline</h2>
        </div>
      </div>

      <div class="cluster-timeline" id="nodeTimelineList">
        <p class="cluster-empty">Loading node activity...</p>
      </div>
    </section>
  </main>
</body>

</html>
{{ end }}