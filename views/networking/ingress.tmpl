{{ define "networking/ingress" }}
<!doctype html>
<html lang="en">

<head>
  <title>NetKube</title>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="/public/logo/favicon.ico" type="image/x-icon" />
  <link rel="apple-touch-icon" href="/public/logo/logo.png" />
  <link rel="stylesheet" href="/public/global.css" />
  <link rel="stylesheet" href="/public/css/overview.css" />
  <link rel="stylesheet" href="/public/css/deployments.css" />
  <script src="/public/js/app/core/storage/local.js" defer></script>
  <script src="/public/js/app/core/dom/text.js" defer></script>
  <script src="/public/js/app/core/dom/page-meta.js" defer></script>
  <script src="/public/js/app/core/refresh/polling.js" defer></script>
  <script src="/public/js/app/core/api/cluster.js" defer></script>
  <script src="/public/js/app/networking/v1/ingress/boot.js" defer></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" />
</head>

<body>
  {{ template "sidebar" . }}
  <main class="main-content dashboard-page deployments-page">
    <section class="dashboard-hero">
      <div>
        <p class="eyebrow">Networking inventory</p>
        <div class="hero-copy">
          <img src="/public/logo/kubernetes.svg" alt="NetKube logo" class="hero-logo" />
          <span class="hero-user" id="ingressHeroTitle">Ingress</span>
        </div>
      </div>

      <div class="hero-meta">
        <div class="meta-pill">
          <span class="meta-label">Context</span>
          <strong id="selectedContext">-</strong>
        </div>
        <div class="meta-pill">
          <span class="meta-label">Last refresh</span>
          <strong id="lastRefresh">just now</strong>
        </div>
      </div>
    </section>

    <section class="deployments-toolbar" aria-label="Ingress controls">
      <div class="deployments-toolbar__left">
        <label class="search-control" for="ingressSearch">
          <i class="fa fa-search" aria-hidden="true"></i>
          <input id="ingressSearch" type="search" placeholder="Search ingress" />
        </label>
      </div>
    </section>

    <section class="deployments-table-panel">
      <div class="deployments-table-panel__header">
        <div>
          <p class="summary-kicker">Ingress</p>
        </div>
        <span class="table-hint" id="ingressTableCount">0 rows</span>
      </div>

      <div class="deployments-table-wrap" role="region" aria-label="Ingress table" tabindex="0">
        <table class="deployments-table">
          <thead>
            <tr>
              <th>Namespace</th>
              <th>Name</th>
              <th>Class</th>
              <th>Hosts</th>
              <th>Address</th>
              <th>Age</th>
            </tr>
          </thead>
          <tbody id="ingressTableBody">
            <tr>
              <td colspan="6">Loading ingress...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>
  </main>
</body>

</html>
{{ end }}