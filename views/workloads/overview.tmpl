{{ define "workloads/overview" }}
<!doctype html>
<html>
  <head>
    <title>NetKube</title>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
        <link rel="icon" type="image/png" href="/public/logo/logo.png" />
        <link rel="stylesheet" href="/public/global.css" />
        <link rel="stylesheet" href="/public/css/overview.css" />

    
    <script src="/public/model/localStorage.js" defer></script>
    <script src="/public/model/clusterApi.js" defer></script>
    <script src="/public/model/workloadsOverview.js" defer></script>

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css"
    />
  </head>
  <body>
      {{ template "sidebar" . }}
        <main class="main-content dashboard-page">
            <section class="dashboard-hero">
                <div>
                    <p class="eyebrow">Cluster snapshot</p>
                    <div class="hero-copy">
                        <img src="/public/logo/kubernetes.svg" alt="NetKube logo" class="hero-logo" />
                        <span class="hero-user" id="heroUser">admin@kube-syd</span>
                    </div>
                </div>

                <div class="hero-meta">
                    <div class="meta-pill">
                        <span class="meta-label">Context</span>
                        <strong id="selectedContext">demo-cluster</strong>
                    </div>
                    <div class="meta-pill">
                        <span class="meta-label">Last refresh</span>
                        <strong id="lastRefresh">just now</strong>
                    </div>
                </div>
            </section>

            <section class="summary-grid" aria-label="Kubernetes resource summary">
                <article class="summary-card summary-card--wide">
                    <div class="summary-card__header">
                        <div class="summary-card__title">
                            <p class="summary-kicker">Workloads</p>
                            <h2>Pods</h2>
                        </div>
                        <div class="summary-card__meta">
                            <span class="status-chip status-chip--healthy" id="podsStatus">Healthy</span>
                            <div class="summary-number" id="podsTotal">0</div>
                        </div>
                    </div>
                    <div class="health-bar" aria-hidden="true">
                        <span class="segment healthy" style="width: 72%"></span>
                        <span class="segment warning" style="width: 18%"></span>
                        <span class="segment danger" style="width: 10%"></span>
                    </div>
                    <div class="summary-breakdown">
                        <div><span id="podsPrimaryLabel">Running</span><strong id="podsPrimary">0</strong></div>
                        <div><span id="podsWarningLabel">Pending</span><strong id="podsWarning">0</strong></div>
                        <div><span id="podsDangerLabel">Failed</span><strong id="podsDanger">0</strong></div>
                        <div><span id="podsOtherLabel">Other</span><strong id="podsOther">0</strong></div>
                    </div>
                </article>

                <article class="summary-card">
                    <div class="summary-card__header">
                        <div class="summary-card__title">
                            <p class="summary-kicker">Deployments</p>
                            <h2>Deployments</h2>
                        </div>
                        <div class="summary-card__meta">
                            <div class="summary-number" id="deploymentsTotal">0</div>
                        </div>
                    </div>
                    <div class="health-bar" aria-hidden="true">
                        <span class="segment healthy" style="width: 84%"></span>
                        <span class="segment warning" style="width: 12%"></span>
                        <span class="segment danger" style="width: 4%"></span>
                    </div>
                    <div class="summary-breakdown">
                        <div><span id="deploymentsPrimaryLabel">Healthy</span><strong id="deploymentsPrimary">0</strong></div>
                        <div><span id="deploymentsWarningLabel">Warning</span><strong id="deploymentsWarning">0</strong></div>
                        <div><span id="deploymentsDangerLabel">Pending</span><strong id="deploymentsDanger">0</strong></div>
                        <div><span id="deploymentsOtherLabel">Other</span><strong id="deploymentsOther">0</strong></div>
                    </div>
                </article>

                <article class="summary-card">
                    <div class="summary-card__header">
                        <div class="summary-card__title">
                            <p class="summary-kicker">Controllers</p>
                            <h2>ReplicaSets</h2>
                        </div>
                        <div class="summary-card__meta">
                            <span class="status-chip status-chip--warning" id="replicaSetsStatus">Attention</span>
                            <div class="summary-number" id="replicaSetsTotal">0</div>
                        </div>
                    </div>
                    <div class="health-bar" aria-hidden="true">
                        <span class="segment healthy" style="width: 61%"></span>
                        <span class="segment warning" style="width: 27%"></span>
                        <span class="segment danger" style="width: 12%"></span>
                    </div>
                    <div class="summary-breakdown">
                        <div><span id="replicaSetsPrimaryLabel">Ready</span><strong id="replicaSetsPrimary">0</strong></div>
                        <div><span id="replicaSetsWarningLabel">Pending</span><strong id="replicaSetsWarning">0</strong></div>
                        <div><span id="replicaSetsDangerLabel">Issues</span><strong id="replicaSetsDanger">0</strong></div>
                        <div><span id="replicaSetsOtherLabel">Other</span><strong id="replicaSetsOther">0</strong></div>
                    </div>
                </article>

                <article class="summary-card">
                    <div class="summary-card__header">
                        <div class="summary-card__title">
                            <p class="summary-kicker">Daemon workload</p>
                            <h2>DaemonSets</h2>
                        </div>
                        <div class="summary-card__meta">
                            <span class="status-chip status-chip--healthy" id="daemonSetsStatus">Normal</span>
                            <div class="summary-number" id="daemonSetsTotal">0</div>
                        </div>
                    </div>
                    <div class="health-bar" aria-hidden="true">
                        <span class="segment healthy" style="width: 79%"></span>
                        <span class="segment warning" style="width: 15%"></span>
                        <span class="segment danger" style="width: 6%"></span>
                    </div>
                    <div class="summary-breakdown">
                        <div><span id="daemonSetsPrimaryLabel">Ready</span><strong id="daemonSetsPrimary">0</strong></div>
                        <div><span id="daemonSetsWarningLabel">Pending</span><strong id="daemonSetsWarning">0</strong></div>
                        <div><span id="daemonSetsDangerLabel">Issues</span><strong id="daemonSetsDanger">0</strong></div>
                        <div><span id="daemonSetsOtherLabel">Other</span><strong id="daemonSetsOther">0</strong></div>
                    </div>
                </article>

                <article class="summary-card">
                    <div class="summary-card__header">
                        <div class="summary-card__title">
                            <p class="summary-kicker">Stateful data</p>
                            <h2>StatefulSets</h2>
                        </div>
                        <div class="summary-card__meta">
                            <span class="status-chip status-chip--warning" id="statefulSetsStatus">Watch</span>
                            <div class="summary-number" id="statefulSetsTotal">0</div>
                        </div>
                    </div>
                    <div class="health-bar" aria-hidden="true">
                        <span class="segment healthy" style="width: 66%"></span>
                        <span class="segment warning" style="width: 20%"></span>
                        <span class="segment danger" style="width: 14%"></span>
                    </div>
                    <div class="summary-breakdown">
                        <div><span id="statefulSetsPrimaryLabel">Ready</span><strong id="statefulSetsPrimary">0</strong></div>
                        <div><span id="statefulSetsWarningLabel">Updating</span><strong id="statefulSetsWarning">0</strong></div>
                        <div><span id="statefulSetsDangerLabel">Issues</span><strong id="statefulSetsDanger">0</strong></div>
                        <div><span id="statefulSetsOtherLabel">Other</span><strong id="statefulSetsOther">0</strong></div>
                    </div>
                </article>

                <article class="summary-card">
                    <div class="summary-card__header">
                        <div class="summary-card__title">
                            <p class="summary-kicker">Schedules</p>
                            <h2>CronJobs</h2>
                        </div>
                        <div class="summary-card__meta">
                            <span class="status-chip status-chip--healthy" id="cronJobsStatus">Light</span>
                            <div class="summary-number" id="cronJobsTotal">0</div>
                        </div>
                    </div>
                    <div class="health-bar" aria-hidden="true">
                        <span class="segment healthy" style="width: 88%"></span>
                        <span class="segment warning" style="width: 8%"></span>
                        <span class="segment danger" style="width: 4%"></span>
                    </div>
                    <div class="summary-breakdown">
                        <div><span id="cronJobsPrimaryLabel">Tracked</span><strong id="cronJobsPrimary">0</strong></div>
                        <div><span id="cronJobsWarningLabel">Warning</span><strong id="cronJobsWarning">0</strong></div>
                        <div><span id="cronJobsDangerLabel">Issues</span><strong id="cronJobsDanger">0</strong></div>
                        <div><span id="cronJobsOtherLabel">Other</span><strong id="cronJobsOther">0</strong></div>
                    </div>
                </article>

                <article class="summary-card">
                    <div class="summary-card__header">
                        <div class="summary-card__title">
                            <p class="summary-kicker">Batch</p>
                            <h2>Jobs</h2>
                        </div>
                        <div class="summary-card__meta">
                            <span class="status-chip status-chip--healthy" id="jobsStatus">Quiet</span>
                            <div class="summary-number" id="jobsTotal">0</div>
                        </div>
                    </div>
                    <div class="health-bar" aria-hidden="true">
                        <span class="segment healthy" style="width: 73%"></span>
                        <span class="segment warning" style="width: 17%"></span>
                        <span class="segment danger" style="width: 10%"></span>
                    </div>
                    <div class="summary-breakdown">
                        <div><span id="jobsPrimaryLabel">Succeeded</span><strong id="jobsPrimary">0</strong></div>
                        <div><span id="jobsWarningLabel">Active</span><strong id="jobsWarning">0</strong></div>
                        <div><span id="jobsDangerLabel">Failed</span><strong id="jobsDanger">0</strong></div>
                        <div><span id="jobsOtherLabel">Other</span><strong id="jobsOther">0</strong></div>
                    </div>
                </article>

                <article class="summary-card">
                    <div class="summary-card__header">
                        <div class="summary-card__title">
                            <p class="summary-kicker">Governance</p>
                            <h2>Resource Quotas</h2>
                        </div>
                        <div class="summary-card__meta">
                            <span class="status-chip status-chip--danger" id="resourceQuotasStatus">Tight</span>
                            <div class="summary-number" id="resourceQuotasTotal">0</div>
                        </div>
                    </div>
                    <div class="health-bar" aria-hidden="true">
                        <span class="segment healthy" style="width: 48%"></span>
                        <span class="segment warning" style="width: 32%"></span>
                        <span class="segment danger" style="width: 20%"></span>
                    </div>
                    <div class="summary-breakdown">
                        <div><span id="resourceQuotasPrimaryLabel">Tracked</span><strong id="resourceQuotasPrimary">0</strong></div>
                        <div><span id="resourceQuotasWarningLabel">Warning</span><strong id="resourceQuotasWarning">0</strong></div>
                        <div><span id="resourceQuotasDangerLabel">Issues</span><strong id="resourceQuotasDanger">0</strong></div>
                        <div><span id="resourceQuotasOtherLabel">Other</span><strong id="resourceQuotasOther">0</strong></div>
                    </div>
                </article>
            </section>

            <section class="abnormalities-panel">
                <div class="abnormalities-panel__header">
                    <div>
                        <p class="summary-kicker">Exceptions</p>
                        <h2>Abnormalities</h2>
                    </div>

                    <label class="filter-control" for="abnormalityFilter">
                        <span>Filter</span>
                        <select id="abnormalityFilter" name="abnormalityFilter">
                            <option>All severities</option>
                            <option>95% of limit</option>
                            <option>Warning</option>
                            <option>Critical</option>
                        </select>
                    </label>
                </div>

                <div class="abnormality-list" id="workloadWarningsList"></div>

                <p class="abnormalities-empty" id="workloadWarningsEmpty">
                    Loading workload warnings...
                </p>
            </section>
        </main>
  </body>
</html>
{{ end }}
