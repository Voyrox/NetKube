{{ define "workloads/manage/pod" }}
<!doctype html>
<html lang="en">

<head>
  <title>NetKube</title>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/png" href="/public/logo/logo.png" />
  <link rel="stylesheet" href="/public/global.css" />
  <link rel="stylesheet" href="/public/css/overview.css" />
  <link rel="stylesheet" href="/public/css/manage/pod.css" />
  <script src="/public/js/app/core/storage/local.js" defer></script>
  <script src="/public/js/app/ui/yaml/highlight.js" defer></script>
  <script src="/public/js/app/core/dom/text.js" defer></script>
  <script src="/public/js/app/core/dom/page-meta.js" defer></script>
  <script src="/public/js/app/core/refresh/polling.js" defer></script>
  <script src="/public/js/app/core/api/cluster.js" defer></script>
  <script src="/public/js/app/workloads/v1/pod/boot.js" defer></script>

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" />
</head>

<body>
  {{ template "sidebar" . }}
  <main class="main-content pod-manage-page">
    <section class="dashboard-hero">
      <div>
        <p class="eyebrow">Workload detail</p>
        <div class="hero-copy">
          <img src="/public/logo/kubernetes.svg" alt="NetKube logo" class="hero-logo" />
          <span class="hero-user" id="podHeroTitle">Pod</span>
        </div>
      </div>

      <div class="hero-meta">
        <div class="meta-pill">
          <span class="meta-label">Namespace</span>
          <strong id="podNamespace">-</strong>
        </div>
        <div class="meta-pill">
          <span class="meta-label">Last refresh</span>
          <strong id="lastRefresh">just now</strong>
        </div>
      </div>
    </section>

    <section class="pod-manage-shell">
      <div class="pod-summary-card">
        <div class="pod-summary-card__header">
          <div>
            <p class="summary-kicker">Pod status</p>
            <h2 id="podName">Loading...</h2>
          </div>
          <span class="status-chip status-chip--healthy" id="podStatus">Healthy</span>
        </div>

        <div class="pod-highlight-grid">
          <article class="pod-highlight-item">
            <span>Ready</span>
            <strong id="podReady">-</strong>
          </article>
          <article class="pod-highlight-item">
            <span>Restarts</span>
            <strong id="podRestarts">0</strong>
          </article>
          <article class="pod-highlight-item">
            <span>Node</span>
            <strong id="podNode">-</strong>
          </article>
          <article class="pod-highlight-item">
            <span>Age</span>
            <strong id="podAge">-</strong>
          </article>
        </div>
      </div>

      <nav class="pod-tabs" aria-label="Pod sections">
        <button class="pod-tab pod-tab--active" type="button" data-pod-tab="overview">Overview</button>
        <button class="pod-tab" type="button" data-pod-tab="logs">Logs</button>
        <button class="pod-tab" type="button" data-pod-tab="events">Events</button>
        <button class="pod-tab" type="button" data-pod-tab="yaml">YAML</button>
      </nav>

      <section class="pod-tab-panel pod-tab-panel--active" data-pod-panel="overview">
        <section class="pod-panel pod-panel--overview">
          <div class="pod-panel__header pod-panel__header--overview">
            <div>
              <p class="summary-kicker">Overview</p>
              <h3>Pod details</h3>
            </div>
            <span class="table-hint">Live workload snapshot</span>
          </div>

          <div class="pod-detail-list pod-detail-list--overview">
            <div><span>Phase</span><strong id="podPhase">-</strong></div>
            <div><span>Service account</span><strong id="podServiceAccount">-</strong></div>
            <div><span>QoS class</span><strong id="podQosClass">-</strong></div>
            <div><span>Pod IP</span><strong id="podPodIP">-</strong></div>
            <div><span>Host IP</span><strong id="podHostIP">-</strong></div>
            <div><span>Started at</span><strong id="podStartTime">-</strong></div>
            <div><span>Last restart</span><strong id="podLastRestart">-</strong></div>
            <div><span>Restart reason</span><strong id="podLastRestartReason">-</strong></div>
          </div>

          <div class="pod-panel__header pod-panel__header--spaced pod-panel__header--section">
            <div>
              <p class="summary-kicker">Runtime</p>
              <h3>Containers</h3>
            </div>
            <span class="table-hint" id="podContainersCount">0 containers</span>
          </div>

          <div class="pod-collection pod-collection--stacked" id="podContainersList">
            <p class="pod-empty">Loading containers...</p>
          </div>

          <div class="pod-panel__header pod-panel__header--spaced pod-panel__header--section">
            <div>
              <p class="summary-kicker">Signals</p>
              <h3>Conditions</h3>
            </div>
          </div>

          <div class="pod-collection pod-collection--stacked" id="podConditionsList">
            <p class="pod-empty">Loading conditions...</p>
          </div>
        </section>

        <section class="pod-panel">
          <div class="pod-panel__header">
            <div>
              <h3>Logs</h3>
            </div>
            <div class="pod-log-toolbar">
              <label class="pod-select-wrap" for="podLogContainerSelect">
                <span>Container</span>
                <select id="podLogContainerSelect"></select>
              </label>
              <span class="table-hint" id="podLogsStatus">Connecting</span>
            </div>
          </div>

          <pre class="pod-code-block" id="podOverviewLogs">Loading logs...</pre>
        </section>
      </section>

      <section class="pod-tab-panel" data-pod-panel="logs">
        <section class="pod-panel pod-panel--full">
          <div class="pod-panel__header">
            <div>
              <p class="summary-kicker">Logs</p>
              <h3>Live container logs</h3>
            </div>
            <div class="pod-log-toolbar">
              <label class="pod-select-wrap" for="podLogsContainerSelect">
                <span>Container</span>
                <select id="podLogsContainerSelect"></select>
              </label>
              <span class="table-hint" id="podLogsStatusFull">Connecting</span>
            </div>
          </div>

          <pre class="pod-code-block pod-code-block--tall" id="podLogsFull">Loading logs...</pre>
        </section>
      </section>

      <section class="pod-tab-panel" data-pod-panel="events">
        <section class="pod-panel pod-panel--full">
          <div class="pod-panel__header">
            <div>
              <p class="summary-kicker">Events</p>
              <h3>Pod activity</h3>
            </div>
          </div>

          <div class="pod-events-list" id="podEventsList">
            <p class="pod-empty">Loading events...</p>
          </div>
        </section>
      </section>

      <section class="pod-tab-panel" data-pod-panel="yaml">
        <section class="pod-panel pod-panel--full">
          <div class="pod-panel__header">
            <div>
              <p class="summary-kicker">Manifest</p>
              <h3>Pod YAML</h3>
            </div>
            <button class="pod-copy-button" type="button" id="podYamlCopyButton">Copy YAML</button>
          </div>

          <div class="pod-yaml-viewer" id="podYamlContent">Loading YAML...</div>
        </section>

        <section class="pod-panel">
          <div class="pod-panel__header">
            <div>
              <p class="summary-kicker">Metadata</p>
              <h3>Labels</h3>
            </div>
          </div>

          <div class="pod-keyvalue-list" id="podLabelsList">
            <p class="pod-empty">Loading labels...</p>
          </div>

          <div class="pod-panel__header pod-panel__header--spaced">
            <div>
              <p class="summary-kicker">Metadata</p>
              <h3>Annotations</h3>
            </div>
          </div>

          <div class="pod-keyvalue-list" id="podAnnotationsList">
            <p class="pod-empty">Loading annotations...</p>
          </div>
        </section>
      </section>
    </section>
  </main>
</body>

</html>
{{ end }}