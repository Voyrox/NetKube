{{ define "workloads/jobs" }}
<!doctype html>
<html lang="en">

<head>
  <title>NetKube</title>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/png" href="/public/logo/logo.png" />
  <link rel="stylesheet" href="/public/global.css" />
  <link rel="stylesheet" href="/public/css/overview.css" />
  <link rel="stylesheet" href="/public/css/deployments.css" />
  <script src="/public/js/app/core/storage/local.js" defer></script>
  <script src="/public/js/app/core/dom/text.js" defer></script>
  <script src="/public/js/app/core/dom/page-meta.js" defer></script>
  <script src="/public/js/app/core/refresh/polling.js" defer></script>
  <script src="/public/js/app/core/api/cluster.js" defer></script>
  <script src="/public/js/app/workloads/v1/jobs/boot.js" defer></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" />
</head>

<body>
  {{ template "sidebar" . }}
  <main class="main-content dashboard-page deployments-page">
    <section class="dashboard-hero">
      <div>
        <p class="eyebrow">Workload inventory</p>
        <div class="hero-copy">
          <img src="/public/logo/kubernetes.svg" alt="NetKube logo" class="hero-logo" />
          <span class="hero-user" id="jobsHeroTitle">Jobs</span>
        </div>
      </div>

      <div class="hero-meta">
        <div class="meta-pill">
          <span class="meta-label">Namespace filter</span>
          <strong id="jobsNamespaceFilter">All namespaces</strong>
        </div>
        <div class="meta-pill">
          <span class="meta-label">Refresh</span>
          <strong id="lastRefresh">Live</strong>
        </div>
      </div>
    </section>

    <section class="deployments-toolbar" aria-label="Job controls">
      <div class="deployments-toolbar__left">
        <label class="search-control" for="jobsSearch">
          <i class="fa fa-search" aria-hidden="true"></i>
          <input id="jobsSearch" type="search" placeholder="Search jobs" />
        </label>
      </div>
    </section>

    <section class="deployments-table-panel">
      <div class="deployments-table-panel__header">
        <div>
          <p class="summary-kicker">Jobs</p>
        </div>
        <span class="table-hint" id="jobsTableCount">0 rows</span>
      </div>

      <div class="deployments-table-wrap" role="region" aria-label="Jobs table" tabindex="0">
        <table class="deployments-table">
          <thead>
            <tr>
              <th>Namespace</th>
              <th>Name</th>
              <th>Status</th>
              <th>Completions</th>
              <th>Active</th>
              <th>Duration</th>
              <th>Age</th>
            </tr>
          </thead>
          <tbody id="jobsTableBody">
            <tr>
              <td colspan="7">Loading jobs...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>
  </main>
</body>

</html>
{{ end }}