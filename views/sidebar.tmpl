            </div>
        </div>
        <div class="nav-dropdown open">
            <button class="nav-dropdown-btn" type="button" aria-expanded="true"><i class="fa fa-share-alt" aria-hidden="true"></i><span>Networking</span><i class="fa fa-chevron-down nav-caret" aria-hidden="true"></i></button>
            <div class="nav-dropdown-content">
                <a href="/networking/services">Services</a>
                <a href="#">Ingress</a>
                <a href="#">Gateways</a>
                <a href="#">HTTP Routes</a>
                <a href="#">Endpoint Slices</a>
