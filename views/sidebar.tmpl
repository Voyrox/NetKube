{{ define "sidebar" }}
<div class="mobile-topbar">
    <button class="mobile-nav-toggle" id="mobileNavToggle" type="button" aria-controls="sidebar" aria-expanded="false"
        aria-label="Open navigation">
        <i class="fa fa-bars" aria-hidden="true"></i>
    </button>
    <a class="mobile-topbar__brand" href="/" aria-label="NetKube home">
        <img src="/public/logo/logo.png" alt="NetKube Logo" />
        <span><span>Net</span><span class="mobile-topbar__accent">Kube</span></span>
    </a>
</div>
<div class="sidebar-backdrop" id="sidebarBackdrop" hidden></div>
<aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
        <img src="/public/logo/logo.png" alt="NetKube Logo" />
        <h2><a style="color: #fff;" href="/">Net</a><span style="color: #4a8bff;">Kube</span></h2>
        <button class="sidebar-close" id="sidebarClose" type="button" aria-label="Close navigation">
            <i class="fa fa-times" aria-hidden="true"></i>
        </button>
    </div>
    <nav class="sidebar-nav">
        <div class="nav-dropdown open" data-sidebar-section="clusters" data-default-open="true">
            <button class="nav-dropdown-btn" type="button" aria-expanded="true"><i class="fa fa-sitemap"
                    aria-hidden="true"></i><span>Clusters</span><i class="fa fa-chevron-down nav-caret"
                    aria-hidden="true"></i></button>
            <div class="nav-dropdown-content">
                <a href="/clusters/overview">Overview</a>
                <a href="/clusters/nodes" data-active-prefixes="/clusters/details/node">Nodes</a>
                <a href="/clusters/events">Events</a>
                <a href="/clusters/namespaces">Namespaces</a>
                <a href="/clusters/leases">Leases</a>
            </div>
        </div>
        <div class="nav-dropdown open" data-sidebar-section="workloads" data-default-open="true">
            <button class="nav-dropdown-btn" type="button" aria-expanded="true"><i class="fa fa-cubes"
                    aria-hidden="true"></i><span>Workloads</span><i class="fa fa-chevron-down nav-caret"
                    aria-hidden="true"></i></button>
            <div class="nav-dropdown-content">
                <a href="/workloads/overview">Overview</a>
                <a href="/workloads/deployments" data-active-prefixes="/workloads/manage/deployment">Deployments</a>
                <a href="/workloads/pods" data-active-prefixes="/workloads/manage/pod">Pods</a>
                <a href="/workloads/replicasets">Replicasets</a>
                <a href="/workloads/daemonsets">Daemonsets</a>
                <a href="/workloads/statefulsets">Statefulsets</a>
                <a href="/workloads/jobs">Jobs</a>
                <a href="/workloads/cronjobs">CronJobs</a>
            </div>
        </div>
        <div class="nav-dropdown open" data-sidebar-section="networking" data-default-open="true">
            <button class="nav-dropdown-btn" type="button" aria-expanded="true"><i class="fa fa-share-alt"
                    aria-hidden="true"></i><span>Networking</span><i class="fa fa-chevron-down nav-caret"
                    aria-hidden="true"></i></button>
            <div class="nav-dropdown-content">
                <a href="/networking/services">Services</a>
                <a href="/networking/ingress">Ingress</a>
                <a href="#">Gateways</a>
                <a href="#">HTTP Routes</a>
                <a href="#">Endpoint Slices</a>
                <a href="#">Network Policies</a>
                <a href="#">Ingress Classes</a>
            </div>
        </div>
        <div class="nav-dropdown" data-sidebar-section="configuration" data-default-open="false">
            <button class="nav-dropdown-btn" type="button" aria-expanded="false"><i class="fa fa-sliders"
                    aria-hidden="true"></i><span>Configuration</span><i class="fa fa-chevron-down nav-caret"
                    aria-hidden="true"></i></button>
            <div class="nav-dropdown-content">
                <a href="/configuration/secrets">Secrets</a>
                <a href="/configuration/configmaps">ConfigMaps</a>
                <a href="/configuration/hpa">HPA</a>
                <a href="/configuration/limitranges">Limit Ranges</a>
                <a href="/configuration/resourcequotas">Resource Quotas</a>
                <a href="/configuration/poddisruptionbudgets">Pod Disruption Budgets</a>
            </div>
        </div>
        <div class="nav-dropdown" data-sidebar-section="storage" data-default-open="false">
            <button class="nav-dropdown-btn" type="button" aria-expanded="false"><i class="fa fa-database"
                    aria-hidden="true"></i><span>Storage</span><i class="fa fa-chevron-down nav-caret"
                    aria-hidden="true"></i></button>
            <div class="nav-dropdown-content">
                <a href="/storage/persistentvolumes">Persistent Volumes</a>
                <a href="/storage/persistentvolumeclaims">Persistent Volume Claims</a>
                <a href="/storage/volumeattachments">Volume Attachments</a>
                <a href="/storage/csinodes">CSI Nodes</a>
                <a href="/storage/csidrivers">CSI Drivers</a>
                <a href="/storage/storageclasses">Storage Classes</a>
                <a href="/storage/volumeattributeclasses">Volume Attribute Classes</a>
            </div>
        </div>
        <div class="nav-dropdown" data-sidebar-section="access-control" data-default-open="false">
            <button class="nav-dropdown-btn" type="button" aria-expanded="false"><i class="fa fa-lock"
                    aria-hidden="true"></i><span>Access Control</span><i class="fa fa-chevron-down nav-caret"
                    aria-hidden="true"></i></button>
            <div class="nav-dropdown-content">
                <a href="#">Service Accounts</a>
                <a href="#">Roles</a>
                <a href="#">Role Bindings</a>
                <a href="#">Cluster Roles</a>
                <a href="#">Cluster Role Bindings</a>
            </div>
        </div>
        <div class="nav-dropdown" data-sidebar-section="administration" data-default-open="false">
            <button class="nav-dropdown-btn" type="button" aria-expanded="false"><i class="fa fa-cogs"
                    aria-hidden="true"></i><span>Administration</span><i class="fa fa-chevron-down nav-caret"
                    aria-hidden="true"></i></button>
            <div class="nav-dropdown-content">
                <a href="#">CRDs</a>
            </div>
        </div>
    </nav>

</aside>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        var SIDEBAR_DROPDOWN_STATE_KEY = "netkube_sidebar_dropdown_state";
        var sidebar = document.getElementById("sidebar");
        var mobileNavToggle = document.getElementById("mobileNavToggle");
        var sidebarClose = document.getElementById("sidebarClose");
        var sidebarBackdrop = document.getElementById("sidebarBackdrop");
        var dropdowns = document.querySelectorAll(".sidebar .nav-dropdown");
        var currentPath = window.location.pathname.replace(/\/+$/, "") || "/";
        var mobileNavMedia = window.matchMedia("(max-width: 900px)");

        function readDropdownState() {
            try {
                return JSON.parse(localStorage.getItem(SIDEBAR_DROPDOWN_STATE_KEY) || "{}");
            } catch (error) {
                return {};
            }
        }

        function writeDropdownState(state) {
            try {
                localStorage.setItem(SIDEBAR_DROPDOWN_STATE_KEY, JSON.stringify(state));
            } catch (error) {
            }
        }

        function dropdownStateKey(dropdown, index) {
            return dropdown.getAttribute("data-sidebar-section") || ("dropdown-" + index);
        }

        function isDropdownOpen(dropdown) {
            return dropdown.classList.contains("open");
        }

        function setDropdownOpen(dropdown, button, isOpen) {
            dropdown.classList.toggle("open", isOpen);
            button.setAttribute("aria-expanded", isOpen ? "true" : "false");
        }

        function persistDropdownStates(dropdowns, state) {
            dropdowns.forEach(function (dropdown, index) {
                state[dropdownStateKey(dropdown, index)] = isDropdownOpen(dropdown);
            });
            writeDropdownState(state);
        }

        function setSidebarOpen(isOpen) {
            if (!sidebar) {
                return;
            }

            sidebar.classList.toggle("is-open", isOpen);
            document.body.classList.toggle("sidebar-open", isOpen && mobileNavMedia.matches);

            if (mobileNavToggle) {
                mobileNavToggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
            }

            if (sidebarBackdrop) {
                sidebarBackdrop.hidden = !isOpen;
                sidebarBackdrop.classList.toggle("is-visible", isOpen);
            }
        }

        function closeSidebar() {
            setSidebarOpen(false);
        }

        function handleViewportChange(event) {
            if (!event.matches) {
                document.body.classList.remove("sidebar-open");
                if (sidebarBackdrop) {
                    sidebarBackdrop.hidden = true;
                    sidebarBackdrop.classList.remove("is-visible");
                }
                if (sidebar) {
                    sidebar.classList.remove("is-open");
                }
                if (mobileNavToggle) {
                    mobileNavToggle.setAttribute("aria-expanded", "false");
                }
            }
        }

        if (mobileNavToggle) {
            mobileNavToggle.addEventListener("click", function () {
                setSidebarOpen(!sidebar.classList.contains("is-open"));
            });
        }

        if (sidebarClose) {
            sidebarClose.addEventListener("click", closeSidebar);
        }

        if (sidebarBackdrop) {
            sidebarBackdrop.addEventListener("click", closeSidebar);
        }

        if (typeof mobileNavMedia.addEventListener === "function") {
            mobileNavMedia.addEventListener("change", handleViewportChange);
        } else if (typeof mobileNavMedia.addListener === "function") {
            mobileNavMedia.addListener(handleViewportChange);
        }

        var dropdownState = readDropdownState();

        dropdowns.forEach(function (dropdown, index) {
            var button = dropdown.querySelector(".nav-dropdown-btn");
            if (!button) {
                return;
            }

            var stateKey = dropdownStateKey(dropdown, index);
            var storedState = dropdownState[stateKey];
            var defaultOpen = dropdown.getAttribute("data-default-open") === "true";
            var links = dropdown.querySelectorAll('.nav-dropdown-content a[href]');
            var hasActiveLink = false;

            links.forEach(function (link) {
                var href = link.getAttribute("href");
                if (!href || href === "#") {
                    return;
                }

                link.addEventListener("click", function () {
                    persistDropdownStates(dropdowns, dropdownState);
                    if (mobileNavMedia.matches) {
                        closeSidebar();
                    }
                });

                var linkPath = new URL(href, window.location.origin).pathname.replace(/\/+$/, "") || "/";
                var activePrefixes = (link.getAttribute("data-active-prefixes") || "")
                    .split(",")
                    .map(function (prefix) {
                        return prefix.trim().replace(/\/+$/, "");
                    })
                    .filter(Boolean);

                var isDirectMatch = linkPath === currentPath;
                var isPrefixMatch = activePrefixes.some(function (prefix) {
                    return currentPath === prefix || currentPath.indexOf(prefix + "/") === 0;
                });

                if (isDirectMatch || isPrefixMatch) {
                    hasActiveLink = true;
                    link.classList.add("is-active");
                    link.setAttribute("aria-current", "page");
                }
            });

            var initialOpen = hasActiveLink;
            if (!initialOpen) {
                initialOpen = typeof storedState === "boolean" ? storedState : defaultOpen;
            }
            setDropdownOpen(dropdown, button, initialOpen);
            dropdownState[stateKey] = initialOpen;

            button.addEventListener("click", function () {
                var isOpen = !isDropdownOpen(dropdown);
                setDropdownOpen(dropdown, button, isOpen);
                dropdownState[stateKey] = isOpen;
                writeDropdownState(dropdownState);
            });
        });

        persistDropdownStates(dropdowns, dropdownState);

        handleViewportChange(mobileNavMedia);
    });
</script>
{{ end }}