<script>
    document.addEventListener("DOMContentLoaded", function () {
        var dropdowns = document.querySelectorAll(".sidebar .nav-dropdown");
        var currentPath = window.location.pathname.replace(/\/+$/, "") || "/";

        dropdowns.forEach(function (dropdown) {
            var button = dropdown.querySelector(".nav-dropdown-btn");
            if (!button) {
                return;
            }

            // Keep aria-expanded synced with actual visibility state.
            button.setAttribute("aria-expanded", dropdown.classList.contains("open") ? "true" : "false");

            button.addEventListener("click", function () {
                var isOpen = dropdown.classList.toggle("open");
                button.setAttribute("aria-expanded", isOpen ? "true" : "false");
            });

            var links = dropdown.querySelectorAll('.nav-dropdown-content a[href]');
            links.forEach(function (link) {
                var href = link.getAttribute("href");
                if (!href || href === "#") {
                    return;
                }

                var linkPath = new URL(href, window.location.origin).pathname.replace(/\/+$/, "") || "/";
                if (linkPath === currentPath) {
                    link.classList.add("is-active");
                    link.setAttribute("aria-current", "page");
                    dropdown.classList.add("open");
                    button.setAttribute("aria-expanded", "true");
                }
            });
        });
    });
</script>
{{ end }}
