        </div>
        <div class="nav-dropdown">
            <button class="nav-dropdown-btn" type="button" aria-expanded="false"><i class="fa fa-sliders" aria-hidden="true"></i><span>Configuration</span><i class="fa fa-chevron-down nav-caret" aria-hidden="true"></i></button>
            <div class="nav-dropdown-content">
