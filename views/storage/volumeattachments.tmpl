{{ define "storage/volumeattachments" }}
<!doctype html>
<html lang="en">

<head>
  <title>NetKube</title>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" href="/public/logo/favicon.ico" type="image/x-icon" />
  <link rel="stylesheet" href="/public/global.css" />
  <link rel="stylesheet" href="/public/css/overview.css" />
  <link rel="stylesheet" href="/public/css/deployments.css" />
  <script src="/public/js/app/core/storage/local.js" defer></script>
  <script src="/public/js/app/core/dom/text.js" defer></script>
  <script src="/public/js/app/core/dom/table.js" defer></script>
  <script src="/public/js/app/core/dom/page-meta.js" defer></script>
  <script src="/public/js/app/core/refresh/polling.js" defer></script>
  <script src="/public/js/app/core/api/cluster.js" defer></script>
  <script src="/public/js/app/storage/v1/volumeattachments/boot.js" defer></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" />
</head>

<body>{{ template "sidebar" . }}<main class="main-content dashboard-page deployments-page">
    <section class="dashboard-hero">
      <div>
        <p class="eyebrow">Storage inventory</p>
        <div class="hero-copy"><img src="/public/logo/kubernetes.svg" alt="NetKube logo" class="hero-logo" /><span
            class="hero-user" id="volumeAttachmentsHeroTitle">Volume Attachments</span></div>
      </div>
      <div class="hero-meta">
        <div class="meta-pill"><span class="meta-label">Context</span><strong id="selectedContext">-</strong></div>
        <div class="meta-pill"><span class="meta-label">Last refresh</span><strong id="lastRefresh">just now</strong>
        </div>
      </div>
    </section>
    <section class="deployments-toolbar" aria-label="Volume attachments controls">
      <div class="deployments-toolbar__left"><label class="search-control" for="volumeAttachmentsSearch"><i
            class="fa fa-search" aria-hidden="true"></i><input id="volumeAttachmentsSearch" type="search"
            placeholder="Search volume attachments" /></label></div>
    </section>
    <section class="deployments-table-panel">
      <div class="deployments-table-panel__header">
        <div>
          <p class="summary-kicker">Volume Attachments</p>
        </div><span class="table-hint" id="volumeAttachmentsTableCount">0 rows</span>
      </div>
      <div class="deployments-table-wrap" role="region" aria-label="Volume attachments table" tabindex="0">
        <table class="deployments-table">
          <thead>
            <tr>
              <th>Name</th>
              <th>Attacher</th>
              <th>Node</th>
              <th>Persistent Volume</th>
              <th>Attached</th>
              <th>Age</th>
            </tr>
          </thead>
          <tbody id="volumeAttachmentsTableBody">
            <tr>
              <td colspan="6">Loading volume attachments...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>
  </main>
</body>

</html>
{{ end }}